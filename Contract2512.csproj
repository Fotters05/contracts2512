<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    
    <!-- Версионирование для автообновлений -->
    <Version>1.0.8</Version>
    <AssemblyVersion>1.0.8.0</AssemblyVersion>
    <FileVersion>1.0.8.0</FileVersion>
    
    <!-- Отключаем генерацию временных проектов WPF для корректной работы с NuGet пакетами -->
    <GenerateTemporaryTargetAssembly>false</GenerateTemporaryTargetAssembly>
    
    <!-- Дополнительные настройки для корректной работы с пакетами в WPF -->
    <SkipWPFTempProjectCreation>true</SkipWPFTempProjectCreation>
    <DisableWPFTempProjectCreation>true</DisableWPFTempProjectCreation>
    
    <!-- Отключаем проверку типов в XAML на этапе компиляции -->
    <SkipXamlMarkupCompilePass1>false</SkipXamlMarkupCompilePass1>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.104.2" />
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.3.0" />
    <PackageReference Include="FreeSpire.Doc" Version="12.2.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.0" />
    <PackageReference Include="Microsoft.Office.Interop.Word" Version="15.0.4797.1004" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="8.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="9.0.0" />
    <PackageReference Include="WPF-UI" Version="4.1.0" />
    
    <!-- Автообновления через Clowd.Squirrel (современная версия для .NET 8) -->
    <!-- Используем PrivateAssets=none чтобы пакет был доступен во временных WPF проектах -->
    <PackageReference Include="Clowd.Squirrel" Version="2.11.1">
      <PrivateAssets>none</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <None Update="App.config">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Remove="migration_*.sql" />
    <Content Remove="migration_*.sql" />
  </ItemGroup>

  <ItemGroup>
    <None Include="migration_*.sql">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Content Include="progaico.ico" />
    <Content Include="splash.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <None Include=".env" Condition="Exists('.env')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Properties\" />
  </ItemGroup>

  <PropertyGroup>
    <!-- Исключаем SQL файлы из анализа SQL Server -->
    <EnableDefaultItems>true</EnableDefaultItems>
    <ApplicationIcon>progaico.ico</ApplicationIcon>
  </PropertyGroup>

</Project>
