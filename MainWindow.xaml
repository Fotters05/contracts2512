<Window x:Class="Contract2512.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Contract2512"
        mc:Ignorable="d"
        Title="Система управления договорами" Height="600" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="1" x:Name="MainTabControl">
            <TabItem Header="Физические лица">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Добавить лицо" x:Name="AddPersonButton" Width="120" Height="30" Margin="0,0,5,0" Click="AddPersonButton_Click"/>
                        <Button Content="Редактировать" x:Name="EditPersonButton" Width="120" Height="30" Margin="0,0,5,0" Click="EditPersonButton_Click"/>
                        <Button Content="Удалить" x:Name="DeletePersonButton" Width="120" Height="30" Margin="0,0,5,0" Click="DeletePersonButton_Click"/>
                        <Button Content="Создать договор" x:Name="CreateContractForPersonButton" Width="150" Height="30" Click="CreateContractForPersonButton_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="PersonsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Дата рождения" Binding="{Binding DateOfBirth, StringFormat=\{0:dd.MM.yyyy\}}" Width="120"/>
                            <DataGridTextColumn Header="СНИЛС" Binding="{Binding Snils}" Width="120"/>
                            <DataGridTextColumn Header="ИНН" Binding="{Binding Inn}" Width="120"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Contacts.ContactPhone}" Width="150"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Contacts.Email}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Договоры">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Создать договор" x:Name="CreateContractButton" Width="150" Height="30" Margin="0,0,5,0" Click="CreateContractButton_Click"/>
                        <Button Content="Просмотреть" x:Name="ViewContractButton" Width="120" Height="30" Click="ViewContractButton_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="ContractsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" Binding="{Binding ContractNumber}" Width="150"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding ContractDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                            <DataGridTextColumn Header="Тип договора" Binding="{Binding ContractType.Name}" Width="*"/>
                            <DataGridTextColumn Header="Программа" Binding="{Binding Program.Name}" Width="*"/>
                            <DataGridTextColumn Header="Заказчик" Binding="{Binding Payer.FullName}" Width="*"/>
                            <DataGridTextColumn Header="Слушатель" Binding="{Binding Listener.FullName}" Width="*"/>
                            <DataGridTextColumn Header="Дата начала" Binding="{Binding StartDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                            <DataGridTextColumn Header="Дата окончания" Binding="{Binding EndDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Программы">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Добавить программу" x:Name="AddProgramButton" Width="150" Height="30" Margin="0,0,5,0" Click="AddProgramButton_Click"/>
                        <Button Content="Редактировать" x:Name="EditProgramButton" Width="120" Height="30" Margin="0,0,5,0" Click="EditProgramButton_Click"/>
                        <Button Content="Удалить" x:Name="DeleteProgramButton" Width="120" Height="30" Click="DeleteProgramButton_Click"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ProgramsItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="5" Padding="10" Width="250" Background="White" Cursor="Hand" 
                                            MouseLeftButtonDown="ProgramCard_MouseLeftButtonDown" Tag="{Binding}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="180"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- CheckBox в правом верхнем углу -->
                                            <Border Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                   Margin="5" Background="White" CornerRadius="3" Opacity="0.9">
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                                         Click="ProgramCheckBox_Click"
                                                         Tag="{Binding}"/>
                                            </Border>

                                            <!-- Изображение -->
                                            <Border Grid.Row="0" Background="LightGray" Margin="0,0,0,10">
                                                <Grid>
                                                    <Image Source="{Binding ImagePath}" Height="150" Stretch="Uniform">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <TextBlock Text="Нет изображения" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ImagePath}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ImagePath}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>

                                            <!-- Контент -->
                                            <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                                <TextBlock FontSize="12" Margin="0,0,0,5">
                                                    <Run Text="Вид программы: " FontWeight="Bold"/>
                                                    <Run Text="{Binding ProgramViewName}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Format}" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                                                <TextBlock>
                                                    <Run Text="Часы: "/>
                                                    <Run Text="{Binding Hours}"/>
                                                </TextBlock>
                                                <TextBlock>
                                                    <Run Text="Уроки: "/>
                                                    <Run Text="{Binding LessonsCount}"/>
                                                </TextBlock>
                                                <TextBlock>
                                                    <Run Text="Цена: "/>
                                                    <Run Text="{Binding Price, StringFormat=\{0:N2\}}"/>
                                                    <Run Text=" руб."/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
