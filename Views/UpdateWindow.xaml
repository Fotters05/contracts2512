<ui:FluentWindow x:Class="Contract2512.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Доступно обновление" 
        Height="450" 
        Width="550"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        ResizeMode="NoResize">
    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0 0" EndPoint="1 1">
            <GradientStop Color="#1E1B4B" Offset="0"/>
            <GradientStop Color="#0F172A" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="TextPrimary" Color="White"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="BorderColor" Color="#475569"/>

        <Style x:Key="UpdateButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#8B5CF6" Opacity="0.9"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="#7C3AED" Opacity="1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LaterButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#4B5563" Opacity="0.6"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="#6B7280" Opacity="0.8"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <Border Grid.Row="0" Background="#312E81" Height="30" MouseDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock Text="Доступно обновление" 
                          Foreground="White" 
                          VerticalAlignment="Center" 
                          Margin="10,0,0,0"
                          FontSize="14"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="🎉 Доступна новая версия!" 
                           FontSize="22" 
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock x:Name="VersionText" 
                           Text="Версия: 1.0.1" 
                           FontSize="16" 
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Что нового -->
            <TextBlock Grid.Row="1" 
                       Text="Что нового:" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,10"/>

            <!-- Описание изменений -->
            <Border Grid.Row="2" 
                    Background="#1E293B" 
                    Opacity="0.7"
                    BorderBrush="{StaticResource BorderColor}" 
                    BorderThickness="1" 
                    CornerRadius="8"
                    Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ReleaseNotesText" 
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               LineHeight="20"/>
                </ScrollViewer>
            </Border>

            <!-- Прогресс бар -->
            <StackPanel Grid.Row="3" Margin="0,20,0,0" x:Name="ProgressPanel" Visibility="Collapsed">
                <TextBlock x:Name="ProgressText" 
                           Text="Скачивание обновления..." 
                           FontSize="13" 
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,8"/>
                <ProgressBar x:Name="ProgressBar" 
                             Height="6" 
                             Minimum="0" 
                             Maximum="100"
                             Foreground="#8B5CF6"
                             Background="#1E293B"/>
            </StackPanel>

            <!-- Кнопки -->
            <StackPanel Grid.Row="4" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button x:Name="UpdateButton" 
                        Content="Обновить сейчас" 
                        Style="{StaticResource UpdateButtonStyle}"
                        Click="UpdateButton_Click"
                        MinWidth="150"
                        Margin="0,0,15,0"/>

                <Button x:Name="LaterButton" 
                        Content="Позже" 
                        Style="{StaticResource LaterButtonStyle}"
                        Click="LaterButton_Click"
                        MinWidth="100"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
