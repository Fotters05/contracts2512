<ui:FluentWindow x:Class="Contract2512.Views.ProgramDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Подробнее о программе" 
        Height="700" 
        Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="ProgramNameText" 
                       Text="Название программы" 
                       FontSize="24" 
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <ui:SymbolIcon Symbol="Clock24" Margin="0,0,5,0"/>
                <TextBlock x:Name="HoursText" Text="0 часов" VerticalAlignment="Center" Margin="0,0,20,0"/>
                
                <ui:SymbolIcon Symbol="Book24" Margin="0,0,5,0"/>
                <TextBlock x:Name="LessonsText" Text="0 занятий" VerticalAlignment="Center" Margin="0,0,20,0"/>
                
                <ui:SymbolIcon Symbol="Money24" Margin="0,0,5,0"/>
                <TextBlock x:Name="PriceText" Text="0 ₽" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- Информация о программе -->
        <ui:Card Grid.Row="1" Margin="0,0,0,15" Padding="15">
            <StackPanel>
                <TextBlock Text="Информация о программе" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,10"/>
                
                <TextBlock x:Name="DescriptionText" 
                           TextWrapping="Wrap" 
                           Margin="0,0,0,10"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                
                <StackPanel x:Name="DocumentPanel" Visibility="Collapsed" Margin="0,5,0,0">
                    <TextBlock Text="Документ об окончании:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DocumentText" 
                               TextWrapping="Wrap" 
                               Margin="0,3,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel x:Name="StandardPanel" Visibility="Collapsed" Margin="0,5,0,0">
                    <TextBlock Text="Профессиональный стандарт:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StandardText" 
                               TextWrapping="Wrap" 
                               Margin="0,3,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </ui:Card>

        <!-- Модули программы -->
        <ui:Card Grid.Row="2" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Содержание программы" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               VerticalAlignment="Center"/>
                    
                    <ui:Button x:Name="LoadFromWebButton"
                               Content="Загрузить с сайта"
                               Icon="{ui:SymbolIcon ArrowDownload24}"
                               Appearance="Secondary"
                               Margin="15,0,0,0"
                               Click="LoadFromWebButton_Click"/>
                    
                    <ui:Button x:Name="AddModuleButton"
                               Content="Добавить модуль"
                               Icon="{ui:SymbolIcon Add24}"
                               Appearance="Secondary"
                               Margin="10,0,0,0"
                               Click="AddModuleButton_Click"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ModulesPanel">
                        <TextBlock x:Name="NoModulesText"
                                   Text="Модули не загружены. Нажмите 'Загрузить с сайта' или добавьте вручную."
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextAlignment="Center"
                                   Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </ui:Card>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,0,0">
            <ui:Button Content="Сохранить" 
                       Appearance="Primary"
                       Icon="{ui:SymbolIcon Save24}"
                       Margin="0,0,10,0"
                       Click="SaveButton_Click"/>
            <ui:Button Content="Закрыть" 
                       Appearance="Secondary"
                       Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
