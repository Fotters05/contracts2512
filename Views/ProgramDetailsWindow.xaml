<ui:FluentWindow x:Class="Contract2512.Views.ProgramDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Подробнее о программе"
        Height="700"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True">

    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0 0" EndPoint="1 1">
            <GradientStop Color="#1E1B4B" Offset="0"/>
            <GradientStop Color="#0F172A" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="TextPrimary" Color="White"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="CardBackground" Color="#1E293B" Opacity="0.32"/>
        <SolidColorBrush x:Key="SectionBackground" Color="#0F172A" Opacity="0.45"/>
        <SolidColorBrush x:Key="BorderColor" Color="#475569"/>
        <SolidColorBrush x:Key="SubtleBorderColor" Color="#334155"/>

        <Style x:Key="DarkButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#4B5563" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="#6B7280" Opacity="0.8"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleStatIconStyle" TargetType="ui:SymbolIcon">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#312E81">
            <Grid MouseDown="TitleBar_MouseDown">
                <TextBlock Text="Подробнее о программе"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           FontSize="14"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock x:Name="ProgramNameText"
                           Text="Название программы"
                           FontSize="28"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextPrimary}"/>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <ui:SymbolIcon Symbol="Clock24" Style="{StaticResource TitleStatIconStyle}"/>
                        <TextBlock x:Name="HoursText" Text="0 часов" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <ui:SymbolIcon Symbol="Book24" Style="{StaticResource TitleStatIconStyle}"/>
                        <TextBlock x:Name="LessonsText" Text="0 занятий" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Money24" Style="{StaticResource TitleStatIconStyle}"/>
                        <TextBlock x:Name="PriceText" Text="0 ₽" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,0,0,15"
                    Padding="18"
                    CornerRadius="12"
                    Background="{StaticResource CardBackground}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Информация о программе"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="DescriptionText"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Foreground="{StaticResource TextSecondary}"/>

                    <StackPanel x:Name="DocumentPanel" Visibility="Collapsed" Margin="0,6,0,0">
                        <TextBlock Text="Документ об окончании:"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="DocumentText"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <StackPanel x:Name="StandardPanel" Visibility="Collapsed" Margin="0,6,0,0">
                        <TextBlock Text="Профессиональный стандарт:"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock x:Name="StandardText"
                                   TextWrapping="Wrap"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Padding="18"
                    CornerRadius="12"
                    Background="{StaticResource CardBackground}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                        <TextBlock Text="Содержание программы"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"
                                   DockPanel.Dock="Left"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <Button x:Name="LoadFromWebButton"
                                    Content="Загрузить с сайта"
                                    Style="{StaticResource DarkButtonStyle}"
                                    Margin="12,0,0,0"
                                    Click="LoadFromWebButton_Click"/>

                            <Button x:Name="AddModuleButton"
                                    Content="Добавить модуль"
                                    Style="{StaticResource DarkButtonStyle}"
                                    Margin="10,0,0,0"
                                    Click="AddModuleButton_Click"/>
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Background="{StaticResource SectionBackground}"
                            BorderBrush="{StaticResource SubtleBorderColor}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ModulesPanel">
                                <TextBlock x:Name="NoModulesText"
                                           Text="Модули не загружены. Нажмите 'Загрузить с сайта' или добавьте вручную."
                                           Foreground="{StaticResource TextMuted}"
                                           TextAlignment="Center"
                                           Margin="0,20,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,15,0,0">
                <Button Content="Сохранить"
                        Style="{StaticResource DarkButtonStyle}"
                        Width="140"
                        Margin="0,0,10,0"
                        Click="SaveButton_Click"/>
                <Button Content="Закрыть"
                        Style="{StaticResource DarkButtonStyle}"
                        Width="120"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
