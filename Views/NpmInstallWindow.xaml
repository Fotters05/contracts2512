<Window x:Class="Contract2512.Views.NpmInstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Installing Parser Dependencies" 
        Height="300" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Installing Parser Dependencies" 
                       FontSize="18" 
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>
            <TextBlock Text="Please wait while npm packages are being installed..." 
                       TextWrapping="Wrap"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- Progress Log -->
        <Border Grid.Row="1" 
                BorderBrush="LightGray" 
                BorderThickness="1" 
                Background="#F5F5F5"
                Margin="0,0,0,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogTextBlock" 
                           Padding="10"
                           FontFamily="Consolas"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Status -->
        <StackPanel Grid.Row="2">
            <ProgressBar x:Name="ProgressBar" 
                         Height="20" 
                         IsIndeterminate="True"
                         Margin="0,0,0,10"/>
            <TextBlock x:Name="StatusTextBlock" 
                       Text="Initializing..." 
                       HorizontalAlignment="Center"
                       Foreground="Gray"/>
        </StackPanel>
    </Grid>
</Window>
