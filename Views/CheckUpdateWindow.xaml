<ui:FluentWindow x:Class="Contract2512.Views.CheckUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Проверка обновлений" 
        Height="250" 
        Width="450"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        ResizeMode="NoResize">
    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0 0" EndPoint="1 1">
            <GradientStop Color="#1E1B4B" Offset="0"/>
            <GradientStop Color="#0F172A" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="TextPrimary" Color="White"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#D1D5DB"/>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom TitleBar -->
        <Border Grid.Row="0" Background="#312E81" Height="30" MouseDown="TitleBar_MouseDown">
            <Grid>
                <TextBlock Text="Проверка обновлений" 
                          Foreground="White" 
                          VerticalAlignment="Center" 
                          Margin="10,0,0,0"
                          FontSize="14"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="30">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Иконка -->
                <TextBlock x:Name="IconTextBlock"
                          Text="🔄"
                          FontSize="48"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,20"/>
                
                <!-- Статус -->
                <TextBlock x:Name="StatusTextBlock"
                          Text="Проверка наличия обновлений..."
                          FontSize="16"
                          FontWeight="SemiBold"
                          Foreground="{StaticResource TextPrimary}"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,10"/>
                
                <!-- Детали -->
                <TextBlock x:Name="DetailsTextBlock"
                          Text="Подключение к серверу..."
                          FontSize="14"
                          Foreground="{StaticResource TextSecondary}"
                          HorizontalAlignment="Center"
                          TextWrapping="Wrap"
                          TextAlignment="Center"
                          MaxWidth="350"
                          Margin="0,0,0,20"/>
                
                <!-- Прогресс бар -->
                <ProgressBar x:Name="ProgressBar"
                            Width="300"
                            Height="4"
                            IsIndeterminate="True"
                            Foreground="#8B5CF6"
                            Background="#1E293B"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
