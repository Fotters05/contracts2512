<Window x:Class="Contract2512.Views.ContractWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Создание договора" Height="680" Width="780"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип договора:" VerticalAlignment="Center" Margin="0,10"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ContractTypeComboBox" DisplayMemberPath="Name" 
                              Margin="0,5" SelectionChanged="ContractTypeComboBox_SelectionChanged"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Номер договора:" VerticalAlignment="Center" Margin="0,10"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="ContractNumberTextBox" Margin="0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата договора:" VerticalAlignment="Center" Margin="0,10"/>
                    <DatePicker Grid.Row="2" Grid.Column="1" x:Name="ContractDatePicker" Margin="0,5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Программа обучения:" VerticalAlignment="Center" Margin="0,10"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="ProgramComboBox" DisplayMemberPath="Name" Margin="0,5"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Дата начала:" VerticalAlignment="Center" Margin="0,10"/>
                    <DatePicker Grid.Row="4" Grid.Column="1" x:Name="StartDatePicker" Margin="0,5"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата окончания:" VerticalAlignment="Center" Margin="0,10"/>
                    <DatePicker Grid.Row="5" Grid.Column="1" x:Name="EndDatePicker" Margin="0,5"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Заказчик:" VerticalAlignment="Center" Margin="0,10"/>
                    <ComboBox Grid.Row="6" Grid.Column="1" x:Name="PayerComboBox" DisplayMemberPath="FullName" Margin="0,5"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Слушатель:" VerticalAlignment="Center" Margin="0,10"/>
                    <ComboBox Grid.Row="7" Grid.Column="1" x:Name="ListenerComboBox" DisplayMemberPath="FullName" Margin="0,5"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Подписант:" VerticalAlignment="Center" Margin="0,10"/>
                    <ComboBox Grid.Row="8" Grid.Column="1" x:Name="SignerComboBox" DisplayMemberPath="Name" Margin="0,5"/>

                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Вариант оплаты:" VerticalAlignment="Center" Margin="0,10"/>
                    <ComboBox Grid.Row="9" Grid.Column="1" x:Name="PaymentOptionComboBox" DisplayMemberPath="Name" Margin="0,5"/>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Учебная нагрузка:" VerticalAlignment="Center" Margin="0,10"/>
                    <ComboBox Grid.Row="10" Grid.Column="1" x:Name="StudyOptionComboBox" DisplayMemberPath="Name" Margin="0,5"/>

                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="CreateContractButton" Content="Создать договор" Width="150" Height="30" 
                   Margin="0,0,10,0" Click="CreateContractButton_Click"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="100" Height="30" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
